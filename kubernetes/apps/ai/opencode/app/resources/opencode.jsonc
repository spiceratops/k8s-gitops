{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m2.5-free",
  "plugin": [
    "cc-safety-net",
    "@tarquinen/opencode-dcp@latest",
    "oh-my-opencode-slim"
  ],
  "mcp": {
    "homelab": {
      "type": "remote",
      "url": "http://vmcp-mcp-gateway-internal.ai.svc.cluster.local:4483/mcp",
      "enabled": true
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "http://litellm.ai.svc.cluster.local/v1",
        "apiKey": "{env:LITELLM_API_KEY}"
      },
      "models": {
        "gpt-oss:20b": {
          "name": "GPT OSS 20b"
        }
      }
    }
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "cors": [
      "https://opencode.${env:CORS_DOMAIN}"
    ]
  }
}